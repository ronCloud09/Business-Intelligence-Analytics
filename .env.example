APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DATABASE_URL=postgresql://your-username:your-password@your-host/your-database?sslmode=require
DB_DATABASE=your-database
DB_USERNAME=your-username
DB_PASSWORD=your-password
DB_SSLMODE=require

MANUFACTURING_DB_URL=postgresql://your-username:your-password@your-host/manufacturing?sslmode=require
INVENTORY_DB_URL=postgresql://your-username:your-password@your-host/inventory?sslmode=require
FULFILLMENT_DB_URL=postgresql://your-username:your-password@your-host/project8?sslmode=require
FINANCE_DB_URL=postgresql://your-username:your-password@your-host/Finance?sslmode=require
ECOMMERCE_DB_URL=postgresql://your-username:your-password@your-host/neondb?sslmode=require
# ITSM_DB_URL=postgresql://your-username:your-password@your-host/itsm?sslmode=require
PROCUREMENT_DB_URL=postgresql://your-username:your-password@your-host/neondb?sslmode=require

MYSQL_SOURCE_HOST=127.0.0.1
MYSQL_SOURCE_PORT=3306
MYSQL_SOURCE_DATABASE=your-database
MYSQL_SOURCE_USERNAME=root
MYSQL_SOURCE_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
AI_GENERATION_INTERVAL_HOURS=12
AI_CACHE_TTL_HOURS=12